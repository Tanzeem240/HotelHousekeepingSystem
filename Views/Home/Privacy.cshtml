@{
    ViewData["Title"] = "About & Team";
}

<!-- Hero -->
<div class="text-center py-4 mb-4">
    <span style="font-size:48px;">&#127968;</span>
    <h1 class="fw-bold mt-2">Hotel Housekeeping System</h1>
    <p class="text-muted">COMP 2154 — System Development Project &nbsp;·&nbsp; Group 24 &nbsp;·&nbsp; Winter 2026</p>
</div>

<!-- About the System -->
<div class="row mb-5">
    <div class="col-md-8 mx-auto">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h4 class="fw-bold mb-3">About the System</h4>
                <p>
                    The <strong>Hotel Housekeeping & Room Status Management System</strong> is a
                    web-based internal application designed to centralize housekeeping workflows,
                    automate room status transitions, and provide real-time operational visibility
                    to hotel staff.
                </p>
                <p>
                    The system replaces manual paper-based processes and verbal communication
                    with a structured digital workflow — reducing delays, improving accountability,
                    and giving management the data they need to operate efficiently.
                </p>
                <h6 class="fw-bold mt-4 mb-2">Key Features</h6>
                <ul class="text-muted">
                    <li>Role-based access control (Manager &amp; Worker)</li>
                    <li>Room lifecycle management (Available → Occupied → Dirty → Available)</li>
                    <li>Automatic housekeeping task creation on guest check-out</li>
                    <li>Task assignment, cleaning, and approval workflow</li>
                    <li>Room categories (Regular, Deluxe, Suite, Presidential)</li>
                    <li>Cleaning time tracking and analytics graph</li>
                    <li>Worker profiles and staff directory</li>
                    <li>Clock in/out and work summary for all staff</li>
                    <li>Daily operational reports</li>
                </ul>
                <h6 class="fw-bold mt-4 mb-2">Technology Stack</h6>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-dark">ASP.NET Core MVC (.NET 9)</span>
                    <span class="badge bg-primary">C#</span>
                    <span class="badge bg-success">PostgreSQL</span>
                    <span class="badge bg-info text-dark">Entity Framework Core</span>
                    <span class="badge bg-secondary">Supabase</span>
                    <span class="badge bg-warning text-dark">Bootstrap 5</span>
                    <span class="badge bg-danger">Chart.js</span>
                </div>
            </div>
        </div>
    </div>
</div>

