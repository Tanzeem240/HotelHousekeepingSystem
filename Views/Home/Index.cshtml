@{
    ViewData["Title"] = "Dashboard";
    bool isManager = Context.Session.GetString("UserRole") == "Manager";
    bool isLoggedIn = Context.Session.GetString("UserName") != null;
    int myUserId = Context.Session.GetInt32("UserId") ?? 0;

    var rooms   = ViewBag.Rooms   as List<HotelHousekeepingSystem.Models.Room>
                  ?? new List<HotelHousekeepingSystem.Models.Room>();
    var tasks   = ViewBag.Tasks   as List<HotelHousekeepingSystem.Models.CleaningTask>
                  ?? new List<HotelHousekeepingSystem.Models.CleaningTask>();
    var myTasks = ViewBag.MyTasks as List<HotelHousekeepingSystem.Models.CleaningTask>
                  ?? new List<HotelHousekeepingSystem.Models.CleaningTask>();

    int available     = rooms.Count(r => r.Status == "Available");
    int occupied      = rooms.Count(r => r.Status == "Occupied");
    int dirty         = rooms.Count(r => r.Status == "Dirty");
    int outOfService  = rooms.Count(r => r.Status == "Out of Service");
    int pendingTasks  = tasks.Count(t => t.Status == "Pending");
    int assignedTasks = tasks.Count(t => t.Status == "Assigned");
    int readyTasks    = tasks.Count(t => t.Status == "Ready");
    int doneToday     = tasks.Count(t => t.Status == "Completed" && t.CreatedAt.Date == DateTime.UtcNow.Date);
}

@if (!isLoggedIn)
{
    <!-- ══════════════ LANDING PAGE ══════════════ -->
    <style>
        .landing-hero {
            background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56db 100%);
            border-radius: 20px;
            padding: 5rem 3rem;
            color: #fff;
            position: relative;
            overflow: hidden;
            margin-bottom: 3rem;
        }
        .landing-hero::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 300px; height: 300px;
            border-radius: 50%;
            background: rgba(255,255,255,.04);
        }
        .landing-hero::after {
            content: '';
            position: absolute;
            bottom: -80px; left: -40px;
            width: 250px; height: 250px;
            border-radius: 50%;
            background: rgba(255,255,255,.03);
        }
        .hero-badge {
            display: inline-block;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 99px;
            padding: .35rem 1rem;
            font-size: .78rem;
            font-weight: 600;
            letter-spacing: .5px;
            text-transform: uppercase;
            color: #93c5fd;
            margin-bottom: 1.5rem;
        }
        .hero-title {
            font-size: 3rem;
            font-weight: 800;
            letter-spacing: -1px;
            line-height: 1.1;
            margin-bottom: 1.25rem;
        }
        .hero-title span { color: #60a5fa; }
        .hero-desc {
            font-size: 1.05rem;
            color: #94a3b8;
            max-width: 560px;
            line-height: 1.7;
            margin-bottom: 2rem;
        }
        .hero-stats {
            display: flex;
            gap: 2.5rem;
            margin-top: 2.5rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(255,255,255,.1);
        }
        .hero-stat-num {
            font-size: 1.6rem;
            font-weight: 800;
            color: #fff;
            line-height: 1;
        }
        .hero-stat-label {
            font-size: .75rem;
            color: #64748b;
            margin-top: 3px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }
        .feature-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 1.75rem;
            height: 100%;
            transition: transform .2s, box-shadow .2s;
        }
        .feature-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 32px rgba(0,0,0,.09);
        }
        .feature-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            margin-bottom: 1rem;
            display: flex; align-items: center; justify-content: center;
            font-size: .7rem;
            font-weight: 800;
            letter-spacing: .5px;
            text-transform: uppercase;
        }
        .feature-title {
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: .5rem;
        }
        .feature-desc {
            font-size: .855rem;
            color: #64748b;
            line-height: 1.6;
        }
        .workflow-step {
            display: flex;
            align-items: flex-start;
            gap: 1.25rem;
            padding: 1.25rem 0;
            border-bottom: 1px solid #f1f5f9;
        }
        .workflow-step:last-child { border-bottom: none; }
        .step-num {
            width: 32px; height: 32px;
            background: #1a56db;
            color: #fff;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: .78rem;
            font-weight: 700;
            flex-shrink: 0;
            margin-top: 2px;
        }
        .step-title {
            font-size: .9rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: .2rem;
        }
        .step-desc {
            font-size: .82rem;
            color: #64748b;
            line-height: 1.5;
        }
        .role-card {
            border-radius: 14px;
            padding: 2rem;
            height: 100%;
        }
        .role-card.manager { background: #f0f4ff; border: 1.5px solid #c7d7fd; }
        .role-card.worker  { background: #f0fdf4; border: 1.5px solid #a7f3d0; }
        .role-title { font-size: 1.1rem; font-weight: 800; color: #0f172a; margin-bottom: .5rem; }
        .role-sub { font-size: .8rem; color: #64748b; margin-bottom: 1.25rem; }
        .role-item {
            display: flex; align-items: center; gap: .6rem;
            font-size: .84rem; color: #374151;
            padding: .35rem 0;
        }
        .role-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .dot-blue   { background: #1a56db; }
        .dot-green  { background: #16a34a; }
        .section-label {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #1a56db;
            margin-bottom: .75rem;
        }
        .section-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -.5px;
            margin-bottom: .75rem;
        }
        .section-desc {
            font-size: .9rem;
            color: #64748b;
            line-height: 1.7;
            max-width: 520px;
        }
    </style>

    <!-- Hero -->
    <div class="landing-hero">
        <div class="hero-badge">COMP 2154 — Group 24 — Winter 2026</div>
        <h1 class="hero-title">
            Hotel Housekeeping<br>
            &amp; <span>Room Management</span><br>
            System
        </h1>
        <p class="hero-desc">
            A centralized, role-based web application for managing hotel room status,
            automating housekeeping workflows, tracking staff activity, and providing
            real-time operational visibility across all departments.
        </p>
        <div class="d-flex gap-3">
            <a asp-controller="Auth" asp-action="Login"
               class="btn btn-primary btn-lg px-4">Sign In</a>
            <a asp-controller="Auth" asp-action="Register"
               class="btn btn-lg px-4"
               style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;">
                Create Account
            </a>
        </div>
        <div class="hero-stats">
            <div>
                <div class="hero-stat-num">7</div>
                <div class="hero-stat-label">Core Modules</div>
            </div>
            <div>
                <div class="hero-stat-num">2</div>
                <div class="hero-stat-label">User Roles</div>
            </div>
            <div>
                <div class="hero-stat-num">12</div>
                <div class="hero-stat-label">Requirements Met</div>
            </div>
            <div>
                <div class="hero-stat-num">.NET 9</div>
                <div class="hero-stat-label">Technology</div>
            </div>
        </div>
    </div>

    <!-- Features -->
    <div class="mb-5">
        <div class="section-label">Platform Capabilities</div>
        <h2 class="section-title">Everything in one place</h2>
        <p class="section-desc mb-4">
            Built for hotel operations — from the front desk to the housekeeping floor,
            every workflow is covered.
        </p>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#dbeafe;color:#1d4ed8;">RM</div>
                    <div class="feature-title">Room Management</div>
                    <div class="feature-desc">
                        Track every room in real time through a complete lifecycle —
                        Available, Occupied, Dirty, Cleaning, Clean, Inspected, and Out of Service.
                        Check-in and check-out events trigger automatic status transitions.
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#dcfce7;color:#15803d;">TW</div>
                    <div class="feature-title">Task Workflow</div>
                    <div class="feature-desc">
                        Cleaning tasks are automatically created when a guest checks out.
                        Supervisors assign tasks to workers, workers mark them complete,
                        and managers approve — all tracked with timestamps.
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fee2e2;color:#b91c1c;">MI</div>
                    <div class="feature-title">Maintenance Tracking</div>
                    <div class="feature-desc">
                        Report and track maintenance issues by room with priority levels.
                        High or critical issues automatically mark rooms Out of Service.
                        Managers resolve issues and restore room availability.
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#ede9fe;color:#6d28d9;">RB</div>
                    <div class="feature-title">Role-Based Access</div>
                    <div class="feature-desc">
                        Managers and workers each see a tailored interface.
                        Managers have full operational control; workers see only
                        their assigned tasks and personal information.
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#fef9c3;color:#a16207;">AN</div>
                    <div class="feature-title">Analytics &amp; Reporting</div>
                    <div class="feature-desc">
                        Visual bar charts show cleaning duration per task and average time
                        per worker. Daily operational reports summarize room status,
                        task completion, and staff activity.
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon" style="background:#ccfbf1;color:#0f766e;">WS</div>
                    <div class="feature-title">Work Summary</div>
                    <div class="feature-desc">
                        Staff clock in and out directly from the system. Every session is
                        recorded with duration. Managers see a live attendance overview
                        showing who is currently on shift.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- How it works -->
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="section-label">How It Works</div>
            <h2 class="section-title">The workflow</h2>
            <p class="section-desc mb-3">
                From guest check-out to clean room approval, every step is
                handled automatically.
            </p>
            <div>
                <div class="workflow-step">
                    <div class="step-num">1</div>
                    <div>
                        <div class="step-title">Guest Check-Out</div>
                        <div class="step-desc">Front desk records a check-out event. The system immediately marks the room as Dirty and creates a housekeeping task.</div>
                    </div>
                </div>
                <div class="workflow-step">
                    <div class="step-num">2</div>
                    <div>
                        <div class="step-title">Task Assignment</div>
                        <div class="step-desc">The supervisor assigns the cleaning task to an available worker. Assignment time is recorded for performance tracking.</div>
                    </div>
                </div>
                <div class="workflow-step">
                    <div class="step-num">3</div>
                    <div>
                        <div class="step-title">Room Cleaning</div>
                        <div class="step-desc">The worker cleans the room and marks the task as complete. The room status updates to Ready for inspection.</div>
                    </div>
                </div>
                <div class="workflow-step">
                    <div class="step-num">4</div>
                    <div>
                        <div class="step-title">Manager Approval</div>
                        <div class="step-desc">The manager reviews and approves. The room returns to Available and cleaning duration is calculated automatically.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Role breakdown -->
        <div class="col-md-6">
            <div class="section-label">User Roles</div>
            <h2 class="section-title">Who uses the system</h2>
            <p class="section-desc mb-3">
                Two roles with clearly separated responsibilities and interfaces.
            </p>
            <div class="row g-3">
                <div class="col-12">
                    <div class="role-card manager">
                        <div class="role-title">Manager</div>
                        <div class="role-sub">Full operational control and reporting</div>
                        <div class="role-item"><span class="role-dot dot-blue"></span>View dashboard with live room and task stats</div>
                        <div class="role-item"><span class="role-dot dot-blue"></span>Record guest check-in and check-out events</div>
                        <div class="role-item"><span class="role-dot dot-blue"></span>Assign and reassign cleaning tasks to workers</div>
                        <div class="role-item"><span class="role-dot dot-blue"></span>Approve completed rooms and maintenance issues</div>
                        <div class="role-item"><span class="role-dot dot-blue"></span>View cleaning analytics and daily reports</div>
                        <div class="role-item"><span class="role-dot dot-blue"></span>Manage staff profiles and work attendance</div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="role-card worker">
                        <div class="role-title">Worker</div>
                        <div class="role-sub">Focused task view and personal tracking</div>
                        <div class="role-item"><span class="role-dot dot-green"></span>View assigned cleaning tasks only</div>
                        <div class="role-item"><span class="role-dot dot-green"></span>Mark tasks as cleaned when complete</div>
                        <div class="role-item"><span class="role-dot dot-green"></span>Report maintenance issues during cleaning</div>
                        <div class="role-item"><span class="role-dot dot-green"></span>Clock in and out to track shift hours</div>
                        <div class="role-item"><span class="role-dot dot-green"></span>View personal work summary and session history</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tech stack -->
    <div class="card mb-5" style="border-radius:16px;">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <div class="section-label">Technology</div>
                    <h3 style="font-weight:800;letter-spacing:-.4px;">Built with modern tools</h3>
                    <p style="color:#64748b;font-size:.875rem;line-height:1.6;">
                        Developed using industry-standard technologies for reliability,
                        maintainability, and structured architecture.
                    </p>
                </div>
                <div class="col-md-8">
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <div style="background:#f8fafc;border-radius:10px;padding:1rem;text-align:center;border:1px solid #e2e8f0;">
                                <div style="font-weight:700;font-size:.85rem;color:#0f172a;">ASP.NET Core</div>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">MVC .NET 9</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div style="background:#f8fafc;border-radius:10px;padding:1rem;text-align:center;border:1px solid #e2e8f0;">
                                <div style="font-weight:700;font-size:.85rem;color:#0f172a;">C#</div>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">Backend language</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div style="background:#f8fafc;border-radius:10px;padding:1rem;text-align:center;border:1px solid #e2e8f0;">
                                <div style="font-weight:700;font-size:.85rem;color:#0f172a;">PostgreSQL</div>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">via Supabase</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div style="background:#f8fafc;border-radius:10px;padding:1rem;text-align:center;border:1px solid #e2e8f0;">
                                <div style="font-weight:700;font-size:.85rem;color:#0f172a;">EF Core</div>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">ORM / migrations</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div style="background:#f8fafc;border-radius:10px;padding:1rem;text-align:center;border:1px solid #e2e8f0;">
                                <div style="font-weight:700;font-size:.85rem;color:#0f172a;">Bootstrap 5</div>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">UI framework</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div style="background:#f8fafc;border-radius:10px;padding:1rem;text-align:center;border:1px solid #e2e8f0;">
                                <div style="font-weight:700;font-size:.85rem;color:#0f172a;">Chart.js</div>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">Analytics graphs</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div style="background:#f8fafc;border-radius:10px;padding:1rem;text-align:center;border:1px solid #e2e8f0;">
                                <div style="font-weight:700;font-size:.85rem;color:#0f172a;">Razor Views</div>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">Server-side UI</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div style="background:#f8fafc;border-radius:10px;padding:1rem;text-align:center;border:1px solid #e2e8f0;">
                                <div style="font-weight:700;font-size:.85rem;color:#0f172a;">Git / GitHub</div>
                                <div style="font-size:.72rem;color:#94a3b8;margin-top:2px;">Version control</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer CTA -->
    <div style="background:#0f172a;border-radius:16px;padding:3rem;text-align:center;margin-bottom:2rem;">
        <p style="color:#64748b;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:.5rem;">
            George Brown College — COMP 2154 — Group 24
        </p>
        <h3 style="color:#fff;font-weight:800;font-size:1.6rem;letter-spacing:-.4px;margin-bottom:.75rem;">
            Ready to get started?
        </h3>
        <p style="color:#475569;font-size:.9rem;margin-bottom:1.5rem;">
            Sign in with your hotel staff credentials to access the system.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Auth" asp-action="Login" class="btn btn-primary px-4">Sign In</a>
            <a asp-controller="Home" asp-action="Privacy"
               style="color:#64748b;font-size:.875rem;display:flex;align-items:center;text-decoration:none;">
               About &amp; Team &rarr;
            </a>
        </div>
    </div>
}
else if (isManager)
{
    <div class="page-header">
        <div>
            <h2>Dashboard</h2>
            <div class="subtitle">Welcome back, @Context.Session.GetString("UserName") — @DateTime.Now.ToString("dddd, MMMM d")</div>
        </div>
        <a asp-controller="Room" asp-action="Create" class="btn btn-primary btn-sm">+ Add Room</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon si-green">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9,22 9,12 15,12 15,22"/>
                    </svg>
                </div>
                <div class="stat-num">@available</div>
                <div class="stat-label">Available Rooms</div>
                <div class="stat-bar sb-green"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon si-amber">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <div class="stat-num">@occupied</div>
                <div class="stat-label">Occupied</div>
                <div class="stat-bar sb-amber"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon si-red">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2">
                        <polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/>
                    </svg>
                </div>
                <div class="stat-num">@dirty</div>
                <div class="stat-label">Needs Cleaning</div>
                <div class="stat-bar sb-red"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon si-gray">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                    </svg>
                </div>
                <div class="stat-num">@outOfService</div>
                <div class="stat-label">Out of Service</div>
                <div class="stat-bar sb-gray"></div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon si-amber">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12,6 12,12 16,14"/>
                    </svg>
                </div>
                <div class="stat-num">@pendingTasks</div>
                <div class="stat-label">Pending Tasks</div>
                <div class="stat-bar sb-amber"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon si-blue">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5"/>
                        <path d="M2 12l10 5 10-5"/>
                    </svg>
                </div>
                <div class="stat-num">@assignedTasks</div>
                <div class="stat-label">In Progress</div>
                <div class="stat-bar sb-blue"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon si-indigo">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                </div>
                <div class="stat-num">@readyTasks</div>
                <div class="stat-label">Awaiting Approval</div>
                <div class="stat-bar sb-indigo"></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon si-teal">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2">
                        <polyline points="20,6 9,17 4,12"/>
                    </svg>
                </div>
                <div class="stat-num">@doneToday</div>
                <div class="stat-label">Completed Today</div>
                <div class="stat-bar sb-teal"></div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">Quick Actions</div>
                <div class="card-body d-flex flex-wrap gap-2">
                    <a asp-controller="Room" asp-action="Index" class="btn-action">Manage Rooms</a>
                    <a asp-controller="CleaningTask" asp-action="Index" class="btn-action">Housekeeping</a>
                    <a asp-controller="Maintenance" asp-action="Index" class="btn-action">Maintenance</a>
                    <a asp-controller="User" asp-action="Index" class="btn-action">Staff</a>
                    <a asp-controller="Home" asp-action="DailyReport" class="btn-action">Daily Report</a>
                    <a asp-controller="Home" asp-action="CleaningAnalytics" class="btn-action">Analytics</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">Today</div>
                <div class="card-body">
                    <div style="font-size:.85rem;color:#374151;">
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span style="color:#64748b;">Total rooms</span>
                            <strong>@(rooms.Count)</strong>
                        </div>
                        <div class="d-flex justify-content-between py-1 border-bottom">
                            <span style="color:#64748b;">Tasks open</span>
                            <strong>@(pendingTasks + assignedTasks)</strong>
                        </div>
                        <div class="d-flex justify-content-between py-1">
                            <span style="color:#64748b;">Completed today</span>
                            <strong style="color:#16a34a;">@doneToday</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (readyTasks > 0)
    {
        <div class="card mb-3" style="border-left: 3px solid #6366f1;">
            <div class="card-header">
                Rooms Awaiting Approval
                <span class="badge badge-ready ms-2">@readyTasks pending</span>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                    <tr><th>Room</th><th>Category</th><th>Cleaned By</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var t in tasks.Where(t => t.Status == "Ready"))
                    {
                        <tr>
                            <td><strong>@t.Room?.RoomNumber</strong></td>
                            <td><span class="badge badge-normal">@(t.Room?.Category ?? "—")</span></td>
                            <td>@t.AssignedUser?.Name</td>
                            <td>
                                <form asp-controller="CleaningTask" asp-action="Approve" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button class="btn btn-sm btn-success">Approve</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else
{
    <div class="page-header">
        <div>
            <h2>My Tasks</h2>
            <div class="subtitle">Welcome, @Context.Session.GetString("UserName")</div>
        </div>
    </div>

    @if (!myTasks.Any())
    {
        <div class="alert alert-info">No tasks assigned to you at the moment.</div>
    }
    else
    {
        <div class="card">
            <div class="card-header">Assigned Tasks</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                    <tr><th>Room</th><th>Category</th><th>Status</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var t in myTasks)
                    {
                        string cls;
                        if      (t.Status == "Assigned")  { cls = "badge-assigned"; }
                        else if (t.Status == "Ready")     { cls = "badge-ready"; }
                        else if (t.Status == "Completed") { cls = "badge-completed"; }
                        else                              { cls = "badge-pending"; }
                        <tr>
                            <td><strong>@t.Room?.RoomNumber</strong></td>
                            <td><span class="badge badge-normal">@(t.Room?.Category ?? "—")</span></td>
                            <td><span class="badge @cls">@t.Status</span></td>
                            <td>
                                @if (t.Status == "Assigned" && t.AssignedUserId == myUserId)
                                {
                                    <form asp-controller="CleaningTask" asp-action="MarkCleaned" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@t.Id" />
                                        <button class="btn btn-sm btn-warning">Mark Cleaned</button>
                                    </form>
                                }
                                else if (t.Status == "Ready")
                                {
                                    <span style="font-size:.8rem;color:#6366f1;font-weight:500;">Awaiting approval</span>
                                }
                                else if (t.Status == "Completed")
                                {
                                    <span style="font-size:.8rem;color:#16a34a;font-weight:500;">Complete</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
