@model IEnumerable<HotelHousekeepingSystem.Models.CleaningTask>

@{
    bool isManager      = ViewBag.IsManager == true;
    int  currentUserId  = ViewBag.CurrentUserId ?? 0;
}

<h2>Housekeeping Tasks</h2>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">No tasks to display.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
        <tr>
            <th>Room</th>
            <th>Category</th>
            <th>Status</th>
            <th>Assigned To</th>
            @if (isManager)
            {
                <th>Assigned At</th>
                <th>Cleaning Time</th>
            }
            <th>Action</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var task in Model)
        {
            <tr>
                <td><strong>@task.Room?.RoomNumber</strong></td>
                <td>
                    <span class="badge bg-secondary">@(task.Room?.Category ?? "—")</span>
                </td>
                <td>
                    @{
                        var badgeClass = task.Status switch
                        {
                            "Pending"              => "bg-warning text-dark",
                            "Assigned"             => "bg-primary",
                            "Ready"                => "bg-info text-dark",
                            "Completed"            => "bg-success",
                            "Maintenance Required" => "bg-danger",
                            _                      => "bg-secondary"
                        };
                    }
                    <span class="badge @badgeClass">@task.Status</span>
                </td>
                <td>@(task.AssignedUser?.Name ?? "Not Assigned")</td>

                @if (isManager)
                {
                    <td>
                        @(task.AssignedAt.HasValue
                            ? task.AssignedAt.Value.ToLocalTime().ToString("MMM d, h:mm tt")
                            : "—")
                    </td>
                    <td>
                        @if (task.CleaningDurationMinutes.HasValue)
                        {
                            var mins = (int)task.CleaningDurationMinutes.Value;
                            if (mins < 60)
                            {
                                <span class="text-success fw-bold">@mins min</span>
                            }
                            else
                            {
                                var h = mins / 60;
                                var m = mins % 60;
                                <span class="text-warning fw-bold">@h h @m min</span>
                            }
                        }
                        else if (task.AssignedAt.HasValue && task.Status != "Completed")
                        {
                            // In progress — show live elapsed time
                            var elapsed = (int)(DateTime.UtcNow - task.AssignedAt.Value).TotalMinutes;
                            <span class="text-info">@elapsed min (in progress)</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                }

                <td>
                    @if (isManager)
                    {
                        if (task.Status == "Pending" && task.AssignedUserId == null)
                        {
                            <form asp-action="Assign" method="post" class="d-flex gap-2 align-items-center">
                                <input type="hidden" name="taskId" value="@task.Id" />
                                <select name="userId" class="form-select form-select-sm" style="max-width:150px">
                                    @foreach (var user in ViewBag.Users ?? new List<HotelHousekeepingSystem.Models.User>())
                                    {
                                        <option value="@user.Id">@user.Name</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-primary btn-sm">Assign</button>
                            </form>
                        }
                        else if (task.Status == "Ready")
                        {
                            <form asp-action="Approve" method="post">
                                <input type="hidden" name="id" value="@task.Id" />
                                <button type="submit" class="btn btn-success btn-sm">Approve</button>
                            </form>
                        }
                        else if (task.Status == "Completed")
                        {
                            <span class="text-success small">&#10003; Completed</span>
                        }
                        else if (task.Status == "Assigned")
                        {
                            <span class="text-muted small">Waiting for worker</span>
                        }
                    }
                    else
                    {
                        if (task.Status == "Assigned" && task.AssignedUserId == currentUserId)
                        {
                            <form asp-action="MarkCleaned" method="post">
                                <input type="hidden" name="id" value="@task.Id" />
                                <button type="submit" class="btn btn-warning btn-sm">Mark Cleaned</button>
                            </form>
                        }
                        else if (task.Status == "Ready")
                        {
                            <span class="text-info small">Awaiting approval</span>
                        }
                        else if (task.Status == "Completed")
                        {
                            <span class="text-success small">&#10003; Done</span>
                        }
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
