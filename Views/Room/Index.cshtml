@model IEnumerable<HotelHousekeepingSystem.Models.Room>

@{
    ViewData["Title"] = "Room Management";
    bool isManager = Context.Session.GetString("UserRole") == "Manager";
}

<h2 class="mt-3">Room Management</h2>

@if (isManager)
{
    <a class="btn btn-primary mb-3" asp-controller="Room" asp-action="Create">
        Add New Room
    </a>
}

<table class="table table-striped table-bordered">
    <thead class="table-dark">
    <tr>
        <th>Room Number</th>
        <th>Category</th>
        <th>Status</th>
        @if (isManager)
        {
            <th>Actions</th>
        }
    </tr>
    </thead>
    <tbody>
    @foreach (var room in Model)
    {
        <tr>
            <td><strong>@room.RoomNumber</strong></td>
            <td>
                @{
                    var categoryClass = room.Category switch
                    {
                        "Presidential" => "bg-warning text-dark",
                        "Suite"        => "bg-purple text-white",
                        "Deluxe"       => "bg-info text-dark",
                        _              => "bg-light text-dark border"
                    };
                }
                <span class="badge @categoryClass">@room.Category</span>
            </td>
            <td>
                @if (room.Status == "Available")
                {
                    <span class="badge bg-success">Available</span>
                }
                else if (room.Status == "Occupied")
                {
                    <span class="badge bg-warning text-dark">Occupied</span>
                }
                else if (room.Status == "Cleaning")
                {
                    <span class="badge bg-info text-dark">Cleaning</span>
                }
                else if (room.Status == "Clean")
                {
                    <span class="badge bg-primary">Clean</span>
                }
                else
                {
                    <span class="badge bg-danger">@room.Status</span>
                }
            </td>
            @if (isManager)
            {
                <td>
                    @if (room.Status == "Available")
                    {
                        <a asp-controller="Room" asp-action="CheckIn"
                           asp-route-id="@room.Id" class="btn btn-success btn-sm">Check In</a>
                    }
                    else if (room.Status == "Occupied")
                    {
                        <a asp-controller="Room" asp-action="CheckOut"
                           asp-route-id="@room.Id" class="btn btn-danger btn-sm">Check Out</a>
                    }
                    else
                    {
                        <span class="text-muted small">No Action</span>
                    }
                </td>
            }
        </tr>
    }
    </tbody>
</table>
