@model HotelHousekeepingSystem.Models.WorkerProfile

@{
    ViewData["Title"] = "My Profile";
    bool isManager = Context.Session.GetString("UserRole") == "Manager";
    string initials = string.IsNullOrEmpty(Model.User?.Name) ? "?" :
        string.Join("", Model.User.Name.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()));
}

<div class="row g-4">

    <!-- Left: Avatar + quick info -->
    <div class="col-md-4">
        <div class="card text-center" style="border-radius:16px;">
            <div class="card-body p-4">
                <!-- Avatar -->
                <div style="width:90px;height:90px;border-radius:50%;
                            background:linear-gradient(135deg,#1a56db,#7c3aed);
                            display:flex;align-items:center;justify-content:center;
                            margin:0 auto 1rem;font-size:1.6rem;font-weight:800;
                            color:#fff;letter-spacing:-1px;">
                    @initials
                </div>

                <h4 style="font-weight:800;color:#0f172a;margin-bottom:.25rem;">
                    @Model.User?.Name
                </h4>

                <span class="badge @(Model.User?.Role == "Manager" ? "badge-manager" : "badge-worker")"
                      style="font-size:.78rem;padding:.4em 1em;">
                    @Model.User?.Role
                </span>

                <hr style="margin:1.25rem 0;border-color:#f1f5f9;">

                <div style="font-size:.82rem;color:#64748b;line-height:2;">
                    <div><strong style="color:#0f172a;">@Model.Email</strong></div>
                    <div>@Model.PhoneNumber</div>
                    <div>@Model.Nationality</div>
                </div>

                <div class="mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-primary btn-sm w-100">Edit Profile</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Details + info rows -->
    <div class="col-md-8">

        <!-- Profile details card -->
        <div class="card mb-3" style="border-radius:16px;">
            <div class="card-header">Profile Information</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <tbody>
                    <tr>
                        <td style="width:35%;color:#94a3b8;font-size:.8rem;font-weight:600;
                                   text-transform:uppercase;letter-spacing:.4px;padding:1rem 1.5rem;">
                            Full Name
                        </td>
                        <td style="font-weight:600;color:#0f172a;padding:1rem 1.5rem;">
                            @Model.User?.Name
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#94a3b8;font-size:.8rem;font-weight:600;
                                   text-transform:uppercase;letter-spacing:.4px;padding:1rem 1.5rem;">
                            Role
                        </td>
                        <td style="padding:1rem 1.5rem;">
                            <span class="badge @(Model.User?.Role == "Manager" ? "badge-manager" : "badge-worker")">
                                @Model.User?.Role
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#94a3b8;font-size:.8rem;font-weight:600;
                                   text-transform:uppercase;letter-spacing:.4px;padding:1rem 1.5rem;">
                            Nationality
                        </td>
                        <td style="font-weight:500;color:#374151;padding:1rem 1.5rem;">
                            @Model.Nationality
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#94a3b8;font-size:.8rem;font-weight:600;
                                   text-transform:uppercase;letter-spacing:.4px;padding:1rem 1.5rem;">
                            Phone
                        </td>
                        <td style="font-weight:500;color:#374151;padding:1rem 1.5rem;">
                            @Model.PhoneNumber
                        </td>
                    </tr>
                    <tr>
                        <td style="color:#94a3b8;font-size:.8rem;font-weight:600;
                                   text-transform:uppercase;letter-spacing:.4px;padding:1rem 1.5rem;">
                            Email
                        </td>
                        <td style="font-weight:500;color:#374151;padding:1rem 1.5rem;">
                            @Model.Email
                        </td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Account info card -->
        <div class="card" style="border-radius:16px;">
            <div class="card-header">Account</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div style="background:#f8fafc;border-radius:10px;padding:1rem;
                                    border:1px solid #e2e8f0;">
                            <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;
                                        letter-spacing:.5px;color:#94a3b8;margin-bottom:.35rem;">
                                System Role
                            </div>
                            <div style="font-size:.9rem;font-weight:700;color:#0f172a;">
                                @Model.User?.Role
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div style="background:#f8fafc;border-radius:10px;padding:1rem;
                                    border:1px solid #e2e8f0;">
                            <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;
                                        letter-spacing:.5px;color:#94a3b8;margin-bottom:.35rem;">
                                System
                            </div>
                            <div style="font-size:.9rem;font-weight:700;color:#0f172a;">
                                Hotel Housekeeping
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
