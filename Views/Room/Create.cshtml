@model HotelHousekeepingSystem.Models.Room

@{
    ViewData["Title"] = "Add New Room";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <h2>Add New Room</h2>

        <form asp-action="Create" method="post" class="mt-3">

            <div class="mb-3">
                <label class="form-label">Room Number</label>
                <input asp-for="RoomNumber" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Category</label>
                <select asp-for="Category" class="form-select">
                    <option value="Regular">Regular</option>
                    <option value="Deluxe">Deluxe</option>
                    <option value="Suite">Suite</option>
                    <option value="Presidential">Presidential</option>
                    <option value="Single">Single</option>
                    <option value="Double">Double</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Save Room</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>

        </form>
    </div>
</div>