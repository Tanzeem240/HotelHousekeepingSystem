@model IEnumerable<HotelHousekeepingSystem.Models.User>

<h2>Workers</h2>

<a asp-action="Create" class="btn btn-primary mb-2">Add New Worker</a>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Name</th>
        <th>Role</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.Name</td>
            <td>@user.Role</td>
        </tr>
    }
    </tbody>
</table>