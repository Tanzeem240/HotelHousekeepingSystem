@model IEnumerable<HotelHousekeepingSystem.Models.Room>

<h2 class="mt-3">Room Management</h2>

<a class="btn btn-primary mb-3" asp-controller="Room" asp-action="Create">
    Add New Room
</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
    <tr>
        <th>Room Number</th>
        <th>Status</th>
        <th>Actions</th>
    </tr>
    </thead>

    <tbody>
    @foreach (var room in Model)
    {
        <tr>
            <td>@room.RoomNumber</td>

            <td>
                <span class="badge bg-info">@room.Status</span>
            </td>

            <td>
                <a asp-controller="Room"
                   asp-action="CheckIn"
                   asp-route-id="@room.Id"
                   class="btn btn-success btn-sm">
                    Check In
                </a>

                <a asp-controller="Room"
                   asp-action="CheckOut"
                   asp-route-id="@room.Id"
                   class="btn btn-danger btn-sm">
                    Check Out
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>