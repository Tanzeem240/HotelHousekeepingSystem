<h2>Login</h2>

<form method="post">
    <div>
        <label>Name</label>
        <input name="name" required />
    </div>

    <button type="submit">Login</button>
</form>

<p style="color:red">@ViewBag.Error</p>

<p>
    Don't have an account? 
    <a href="/Auth/Register">Register here</a>
</p>