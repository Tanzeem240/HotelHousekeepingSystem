@{
    ViewData["Title"] = "Dashboard";
    bool isManager = Context.Session.GetString("UserRole") == "Manager";
    bool isLoggedIn = Context.Session.GetString("UserName") != null;
    int myUserId = Context.Session.GetInt32("UserId") ?? 0;

    var rooms = ViewBag.Rooms as List<HotelHousekeepingSystem.Models.Room>
                ?? new List<HotelHousekeepingSystem.Models.Room>();
    var tasks = ViewBag.Tasks as List<HotelHousekeepingSystem.Models.CleaningTask>
                ?? new List<HotelHousekeepingSystem.Models.CleaningTask>();
    var myTasks = ViewBag.MyTasks as List<HotelHousekeepingSystem.Models.CleaningTask>
                  ?? new List<HotelHousekeepingSystem.Models.CleaningTask>();

    int available     = rooms.Count(r => r.Status == "Available");
    int occupied      = rooms.Count(r => r.Status == "Occupied");
    int dirty         = rooms.Count(r => r.Status == "Dirty");
    int outOfService  = rooms.Count(r => r.Status == "Out of Service");
    int pendingTasks  = tasks.Count(t => t.Status == "Pending");
    int assignedTasks = tasks.Count(t => t.Status == "Assigned");
    int readyTasks    = tasks.Count(t => t.Status == "Ready");
    int doneToday     = tasks.Count(t => t.Status == "Completed" && t.CreatedAt.Date == DateTime.UtcNow.Date);
}

@if (!isLoggedIn)
{
    <!-- LANDING PAGE -->
    <div class="text-center py-5">
        <div class="mb-4">
            <span style="font-size:64px;">&#127968;</span>
        </div>
        <h1 class="display-4 fw-bold">Hotel Housekeeping System</h1>
        <p class="lead text-muted mt-3 mb-4">
            A centralized platform for managing hotel room status, housekeeping tasks,<br />
            staff coordination, and operational reporting — all in one place.
        </p>
        <div class="d-flex justify-content-center gap-3 mb-5">
            <a asp-controller="Auth" asp-action="Login"
               class="btn btn-primary btn-lg px-5">Login</a>
            <a asp-controller="Auth" asp-action="Register"
               class="btn btn-outline-secondary btn-lg px-5">Register</a>
        </div>
    </div>

    <hr class="my-4" />

    <!-- Features -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <div style="font-size:36px;" class="mb-3">&#128196;</div>
                    <h5 class="fw-bold">Room Management</h5>
                    <p class="text-muted">Track every room's status in real time — Available, Occupied, Dirty, Cleaning, and more.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <div style="font-size:36px;" class="mb-3">&#9989;</div>
                    <h5 class="fw-bold">Task Workflow</h5>
                    <p class="text-muted">Automatically create cleaning tasks on check-out. Assign, clean, inspect, and approve with one click.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <div style="font-size:36px;" class="mb-3">&#128200;</div>
                    <h5 class="fw-bold">Analytics</h5>
                    <p class="text-muted">Visual reports on cleaning times, worker performance, and daily operations for management.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <div style="font-size:36px;" class="mb-3">&#128100;</div>
                    <h5 class="fw-bold">Role-Based Access</h5>
                    <p class="text-muted">Managers and workers each see only what's relevant to their role — no clutter, no confusion.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <div style="font-size:36px;" class="mb-3">&#128336;</div>
                    <h5 class="fw-bold">Work Tracking</h5>
                    <p class="text-muted">Clock in and out to track shift hours. Managers see all staff attendance in one summary view.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-3">
                <div class="card-body">
                    <div style="font-size:36px;" class="mb-3">&#128101;</div>
                    <h5 class="fw-bold">Worker Profiles</h5>
                    <p class="text-muted">Store and manage staff contact info, nationality, and role details in a centralized directory.</p>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4" />

    <!-- About / Team teaser -->
    <div class="text-center mb-5">
        <h4 class="fw-bold">Built by Group 24 — COMP 2154</h4>
        <p class="text-muted">Tanzeem Shaikh &amp; Daviti Sidana &nbsp;·&nbsp; George Brown College &nbsp;·&nbsp; Winter 2026</p>
        <a asp-controller="Home" asp-action="Privacy" class="btn btn-outline-dark mt-2">
            Meet the Team &rarr;
        </a>
    </div>
}
else if (isManager)
{
    <h2 class="mt-3">Dashboard</h2>
    <p class="text-muted">Welcome back, <strong>@Context.Session.GetString("UserName")</strong></p>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card text-center border-success shadow-sm">
                <div class="card-body">
                    <h2 class="text-success">@available</h2>
                    <p class="text-muted mb-0">Available</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-warning shadow-sm">
                <div class="card-body">
                    <h2 class="text-warning">@occupied</h2>
                    <p class="text-muted mb-0">Occupied</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-danger shadow-sm">
                <div class="card-body">
                    <h2 class="text-danger">@dirty</h2>
                    <p class="text-muted mb-0">Dirty</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-secondary shadow-sm">
                <div class="card-body">
                    <h2 class="text-secondary">@outOfService</h2>
                    <p class="text-muted mb-0">Out of Service</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h2 class="text-warning">@pendingTasks</h2>
                    <p class="text-muted mb-0">Pending Tasks</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h2 class="text-primary">@assignedTasks</h2>
                    <p class="text-muted mb-0">In Progress</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h2 class="text-info">@readyTasks</h2>
                    <p class="text-muted mb-0">Awaiting Approval</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-success shadow-sm">
                <div class="card-body">
                    <h2 class="text-success">@doneToday</h2>
                    <p class="text-muted mb-0">Completed Today</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header"><strong>Quick Actions</strong></div>
        <div class="card-body d-flex flex-wrap gap-2">
            <a asp-controller="Room" asp-action="Index" class="btn btn-outline-primary">Manage Rooms</a>
            <a asp-controller="CleaningTask" asp-action="Index" class="btn btn-outline-success">Housekeeping Tasks</a>
            <a asp-controller="User" asp-action="Index" class="btn btn-outline-secondary">Staff List</a>
            <a asp-controller="Home" asp-action="DailyReport" class="btn btn-outline-dark">Daily Report</a>
            <a asp-controller="Home" asp-action="CleaningAnalytics" class="btn btn-outline-info">Cleaning Analytics</a>
        </div>
    </div>

    @if (readyTasks > 0)
    {
        <div class="card shadow-sm border-info mb-3">
            <div class="card-header bg-info text-white">
                <strong>Rooms Awaiting Approval (@readyTasks)</strong>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                    <tr><th>Room</th><th>Cleaned By</th><th>Action</th></tr>
                    </thead>
                    <tbody>
                    @foreach (var t in tasks.Where(t => t.Status == "Ready"))
                    {
                        <tr>
                            <td>@t.Room?.RoomNumber</td>
                            <td>@t.AssignedUser?.Name</td>
                            <td>
                                <form asp-controller="CleaningTask" asp-action="Approve" method="post">
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button class="btn btn-sm btn-success">Approve</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
else
{
    <h2 class="mt-3">My Tasks</h2>
    <p class="text-muted">Welcome, <strong>@Context.Session.GetString("UserName")</strong></p>

    @if (!myTasks.Any())
    {
        <div class="alert alert-info">No tasks assigned to you.</div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
            <tr><th>Room</th><th>Category</th><th>Status</th><th>Action</th></tr>
            </thead>
            <tbody>
            @foreach (var t in myTasks)
            {
                string cls;
                if (t.Status == "Assigned")      { cls = "bg-primary"; }
                else if (t.Status == "Ready")     { cls = "bg-info text-dark"; }
                else if (t.Status == "Completed") { cls = "bg-success"; }
                else                              { cls = "bg-secondary"; }
                <tr>
                    <td>@t.Room?.RoomNumber</td>
                    <td><span class="badge bg-secondary">@(t.Room?.Category ?? "—")</span></td>
                    <td><span class="badge @cls">@t.Status</span></td>
                    <td>
                        @if (t.Status == "Assigned" && t.AssignedUserId == myUserId)
                        {
                            <form asp-controller="CleaningTask" asp-action="MarkCleaned" method="post">
                                <input type="hidden" name="id" value="@t.Id" />
                                <button class="btn btn-sm btn-warning">Mark Cleaned</button>
                            </form>
                        }
                        else if (t.Status == "Ready")
                        {
                            <span class="text-info small">Awaiting approval</span>
                        }
                        else if (t.Status == "Completed")
                        {
                            <span class="text-success">Done</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
}
