@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="alert alert-danger p-4">
                <h2 class="mb-3">&#x26A0; Access Denied</h2>
                <p class="mb-1">You don't have permission to view this page.</p>
                <p class="text-muted small">This area requires the Manager role.</p>
            </div>
            <a asp-controller="Room" asp-action="Index" class="btn btn-primary me-2">Go to Rooms</a>
            <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-secondary">Log Out</a>
        </div>
    </div>
</div>