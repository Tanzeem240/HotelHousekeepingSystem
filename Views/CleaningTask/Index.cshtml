@model IEnumerable<HotelHousekeepingSystem.Models.CleaningTask>

<h2>Housekeeping Tasks</h2>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Room ID</th>
        <th>Status</th>
        <th>Assigned To</th>
        <th>Assign Worker</th>
    </tr>
    </thead>

    <tbody>
    @foreach (var task in Model)
    {
        <tr>
            <td>@task.Room.RoomNumber</td>
            <td>
                @if (task.Status == "Pending")
                {
                    <span class="badge bg-warning text-dark">Pending</span>
                }
                else if (task.Status == "Completed")
                {
                    <span class="badge bg-success">Completed</span>
                }
                else
                {
                    <span class="badge bg-secondary">@task.Status</span>
                }
            </td>

            <!-- Assigned User -->
            <td>
                @(task.AssignedUser != null ? task.AssignedUser.Name : "Not Assigned")
            </td>
            
            <td>
                @if (task.Status == "Completed")
                {
                    <!-- After approve -->
                    <span class="text-success">Completed</span>
                }
                else if (task.AssignedUserId == null)
                {
                    <!-- Show Assign -->
                    <form asp-action="Assign" method="post">
                        <input type="hidden" name="taskId" value="@task.Id" />

                        <select name="userId" class="form-control">
                            @foreach (var user in ViewBag.Users)
                            {
                                <option value="@user.Id">@user.Name</option>
                            }
                        </select>

                        <button type="submit" class="btn btn-primary btn-sm mt-1">
                            Assign
                        </button>
                    </form>
                }
                else
                {
                    <!-- Show Approve -->
                    <form asp-action="Approve" method="post">
                        <input type="hidden" name="id" value="@task.Id" />

                        <button type="submit" class="btn btn-success btn-sm">
                            Approve
                        </button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>