@{
    ViewData["Title"] = "Add Worker Profile";
    bool isManager = Context.Session.GetString("UserRole") == "Manager";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2>Add Worker Profile</h2>

        <form asp-action="Create" method="post" class="mt-3">
            @Html.AntiForgeryToken()

            @if (isManager)
            {
                <div class="mb-3">
                    <label class="form-label">Worker</label>
                    <select name="UserId" class="form-select" required>
                        <option value="">-- Select Worker --</option>
                        @if (ViewBag.Workers != null)
                        {
                            foreach (var w in (IEnumerable<HotelHousekeepingSystem.Models.User>)ViewBag.Workers)
                            {
                                <option value="@w.Id">@w.Name (@w.Role)</option>
                            }
                        }
                    </select>
                </div>
            }
            else
            {
                <input type="hidden" name="UserId" value="@ViewBag.UserId" />
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" value="@ViewBag.UserName" disabled />
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Nationality</label>
                <input name="Nationality" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input name="PhoneNumber" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input name="Email" type="email" class="form-control" required />
            </div>

            <button type="submit" class="btn btn-primary">Save Profile</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
