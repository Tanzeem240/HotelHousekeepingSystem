@model HotelHousekeepingSystem.Models.WorkerProfile

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <h2>Edit Profile — @Model.User.Name</h2>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="mt-3">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Nationality</label>
                <input name="Nationality" class="form-control"
                       value="@Model.Nationality" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input name="PhoneNumber" class="form-control"
                       value="@Model.PhoneNumber" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input name="Email" type="email" class="form-control"
                       value="@Model.Email" required />
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>