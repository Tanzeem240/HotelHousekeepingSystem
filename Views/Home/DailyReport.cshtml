@{
    ViewData["Title"] = "Daily Report";
    var rooms = ViewBag.Rooms as List<HotelHousekeepingSystem.Models.Room>
                ?? new List<HotelHousekeepingSystem.Models.Room>();
    var tasks = ViewBag.Tasks as List<HotelHousekeepingSystem.Models.CleaningTask>
                ?? new List<HotelHousekeepingSystem.Models.CleaningTask>();

    int totalRooms    = rooms.Count;
    int available     = rooms.Count(r => r.Status == "Available");
    int occupied      = rooms.Count(r => r.Status == "Occupied");
    int dirty         = rooms.Count(r => r.Status == "Dirty");
    int completed     = tasks.Count(t => t.Status == "Completed");
    int pending       = tasks.Count(t => t.Status == "Pending");
    int assigned      = tasks.Count(t => t.Status == "Assigned");
}

<h2 class="mt-3">Daily Report</h2>
<p class="text-muted">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</p>

<!-- Room Summary -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center border-secondary shadow-sm">
            <div class="card-body">
                <h2 class="card-title">@totalRooms</h2>
                <p class="card-text text-muted mb-0">Total Rooms</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-success shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-success">@available</h2>
                <p class="card-text text-muted mb-0">Available</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-warning shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-warning">@occupied</h2>
                <p class="card-text text-muted mb-0">Occupied</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-danger shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-danger">@dirty</h2>
                <p class="card-text text-muted mb-0">Dirty</p>
            </div>
        </div>
    </div>
</div>

<!-- Task Summary -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center border-success shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-success">@completed</h2>
                <p class="card-text text-muted mb-0">Tasks Completed Today</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center border-primary shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-primary">@assigned</h2>
                <p class="card-text text-muted mb-0">In Progress</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center border-warning shadow-sm">
            <div class="card-body">
                <h2 class="card-title text-warning">@pending</h2>
                <p class="card-text text-muted mb-0">Pending</p>
            </div>
        </div>
    </div>
</div>

<!-- Task Detail Table -->
@if (tasks.Any())
{
    <div class="card shadow-sm mb-4">
        <div class="card-header"><strong>Today's Tasks</strong></div>
        <div class="card-body p-0">
            <table class="table table-striped table-sm mb-0">
                <thead class="table-dark">
                <tr>
                    <th>Room</th>
                    <th>Category</th>
                    <th>Assigned To</th>
                    <th>Status</th>
                    <th>Duration</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var t in tasks)
                {
                    var mins = (int)(t.CleaningDurationMinutes ?? 0);
                    <tr>
                        <td><strong>@t.Room?.RoomNumber</strong></td>
                        <td><span class="badge bg-secondary">@(t.Room?.Category ?? "—")</span></td>
                        <td>@(t.AssignedUser?.Name ?? "Unassigned")</td>
                        <td>
                            @{
                                var cls = t.Status switch {
                                    "Completed" => "bg-success",
                                    "Assigned"  => "bg-primary",
                                    "Ready"     => "bg-info text-dark",
                                    "Pending"   => "bg-warning text-dark",
                                    _           => "bg-secondary"
                                };
                            }
                            <span class="badge @cls">@t.Status</span>
                        </td>
                        <td>
                            @if (mins > 0)
                            { <span>@mins min</span> }
                            else
                            { <span class="text-muted">—</span> }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">No tasks created today.</div>
}

<a asp-controller="Home" asp-action="Index" class="btn btn-secondary">← Back to Dashboard</a>
