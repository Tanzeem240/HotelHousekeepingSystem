<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Hotel Housekeeping</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/HotelHousekeepingSystem.styles.css" asp-append-version="true"/>
</head>
<body>

@{
    var role     = Context.Session.GetString("UserRole");
    var userName = Context.Session.GetString("UserName");
    bool loggedIn  = !string.IsNullOrEmpty(userName);
    bool isManager = role == "Manager";
    bool isWorker  = role == "Worker";
    string initials = string.IsNullOrEmpty(userName) ? "?" :
        string.Join("", userName.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper()));
    string pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
}

@if (!loggedIn)
{
    <!-- NO SIDEBAR for guests -->
    <div class="no-sidebar">
        <div class="main-content">
            <div class="topbar">
                <span class="topbar-title">Hotel Housekeeping System</span>
                <a href="/Auth/Login" class="btn btn-primary btn-sm px-3">Login</a>
            </div>
            <div class="page-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4">
                         @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
        <footer class="app-footer no-sidebar">
            <span>&copy; 2026 Hotel Housekeeping System — Group 24</span>
            <a asp-controller="Home" asp-action="Privacy">About &amp; Team</a>
        </footer>
    </div>
}
else
{
    <!-- SIDEBAR LAYOUT for authenticated users -->
    <div class="app-wrapper">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon">H</div>
                <span class="brand-name">Hotel Housekeeping</span>
                <span class="brand-sub">Management System</span>
            </div>

            <nav class="sidebar-nav">

                @if (isManager)
                {
                    <div class="sidebar-section">Main</div>
                    <a class="sidebar-link" asp-controller="Home" asp-action="Index">
                        <span class="s-icon">DB</span> Dashboard
                    </a>
                    <a class="sidebar-link" asp-controller="Room" asp-action="Index">
                        <span class="s-icon">RM</span> Rooms
                    </a>
                    <a class="sidebar-link" asp-controller="CleaningTask" asp-action="Index">
                        <span class="s-icon">HK</span> Housekeeping
                    </a>
                    <a class="sidebar-link" asp-controller="Maintenance" asp-action="Index">
                        <span class="s-icon">MT</span> Maintenance
                    </a>

                    <div class="sidebar-section">People</div>
                    <a class="sidebar-link" asp-controller="User" asp-action="Index">
                        <span class="s-icon">SF</span> Staff
                    </a>
                    <a class="sidebar-link" asp-controller="User" asp-action="WorkSummary">
                        <span class="s-icon">WS</span> Work Summary
                    </a>

                    <div class="sidebar-section">Reports</div>
                    <a class="sidebar-link" asp-controller="Home" asp-action="DailyReport">
                        <span class="s-icon">DR</span> Daily Report
                    </a>
                    <a class="sidebar-link" asp-controller="Home" asp-action="CleaningAnalytics">
                        <span class="s-icon">AN</span> Analytics
                    </a>
                }
                else if (isWorker)
                {
                    <div class="sidebar-section">My Work</div>
                    <a class="sidebar-link" asp-controller="CleaningTask" asp-action="Index">
                        <span class="s-icon">TK</span> My Tasks
                    </a>
                    <a class="sidebar-link" asp-controller="Maintenance" asp-action="Index">
                        <span class="s-icon">MT</span> Maintenance
                    </a>
                    <a class="sidebar-link" asp-controller="User" asp-action="WorkSummary">
                        <span class="s-icon">WS</span> Work Summary
                    </a>

                    <div class="sidebar-section">Profile</div>
                    <a class="sidebar-link" asp-controller="WorkerProfile" asp-action="Index">
                        <span class="s-icon">PR</span> My Profile
                    </a>
                }

            </nav>

            <!-- User card at bottom -->
            <div class="sidebar-user">
                <div class="s-avatar">@initials</div>
                <div>
                    <div class="s-user-name">@userName</div>
                    <div class="s-user-role">@role</div>
                </div>
                <a href="/Auth/Logout" class="s-logout" title="Sign out">&rsaquo;</a>
            </div>
        </aside>

        <!-- Main -->
        <div class="main-content">

            <!-- Top bar -->
            <div class="topbar">
                <span class="topbar-title">@pageTitle</span>
                <div class="topbar-right">
                    <a asp-controller="WorkerProfile" asp-action="Index" class="notif-btn" title="My Profile">
                        &#128100;
                    </a>
                    <a href="/Auth/Logout" class="notif-btn" title="Sign out"
                       style="font-size:1rem;">
                        &rarr;
                    </a>
                </div>
            </div>

            <!-- Page content -->
            <div class="page-content">

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4">
                         @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-4">
                         @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()

            </div>
        </div>

    </div>

    <footer class="app-footer">
        <span>&copy; 2026 Hotel Housekeeping System — Group 24</span>
        <a asp-controller="Home" asp-action="Privacy">About &amp; Team</a>
    </footer>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
