@model IEnumerable<HotelHousekeepingSystem.Models.User>

@{
    ViewData["Title"] = "All Staff";
}

<h2 class="mt-3">All Staff</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Add New Worker</a>

@if (!Model.Any())
{
    <div class="alert alert-info">No staff found.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Role</th>
            <th>Nationality</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td><strong>@user.Name</strong></td>
                <td>
                    @if (user.Role == "Manager")
                    {
                        <span class="badge bg-dark">Manager</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@user.Role</span>
                    }
                </td>
                @if (user.WorkerProfile != null)
                {
                    <td>@user.WorkerProfile.Nationality</td>
                    <td>@user.WorkerProfile.PhoneNumber</td>
                    <td>@user.WorkerProfile.Email</td>
                    <td>
                        <a asp-controller="WorkerProfile" asp-action="Edit"
                           asp-route-id="@user.WorkerProfile.Id"
                           class="btn btn-sm btn-warning">Edit Profile</a>
                    </td>
                }
                else
                {
                    <td colspan="3" class="text-muted fst-italic">No profile yet</td>
                    <td>
                        <a asp-controller="WorkerProfile" asp-action="Create"
                           class="btn btn-sm btn-outline-primary">Add Profile</a>
                    </td>
                }
            </tr>
        }
        </tbody>
    </table>
}
