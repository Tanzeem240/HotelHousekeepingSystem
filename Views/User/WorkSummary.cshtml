@{
    ViewData["Title"] = "Work Summary";
    bool isManager = ViewBag.IsManager == true;

    // Worker variables
    var mySessions  = ViewBag.MySessions  as List<HotelHousekeepingSystem.Models.WorkSession>
                      ?? new List<HotelHousekeepingSystem.Models.WorkSession>();
    var openSession = ViewBag.OpenSession as HotelHousekeepingSystem.Models.WorkSession;
    double todayHours = ViewBag.TodayHours ?? 0;
    double weekHours  = ViewBag.WeekHours  ?? 0;
    double totalHours = ViewBag.TotalHours ?? 0;
    string userName   = ViewBag.UserName   ?? "";

    // Manager variables
    var allSessions = ViewBag.AllSessions as List<HotelHousekeepingSystem.Models.WorkSession>
                      ?? new List<HotelHousekeepingSystem.Models.WorkSession>();
}

<h2 class="mt-3">Work Summary</h2>

@if (!isManager)
{
    <p class="text-muted">Welcome, <strong>@userName</strong></p>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm @(openSession != null ? "border-success" : "border-secondary")">
                <div class="card-body text-center">
                    @if (openSession != null)
                    {
                        <h5 class="text-success">&#9679; Currently Clocked In</h5>
                        <p class="text-muted small mb-3">
                            Since @openSession.ClockInTime.ToLocalTime().ToString("MMM d, h:mm tt")
                        </p>
                        <a asp-action="ClockOut" class="btn btn-danger w-100">Clock Out</a>
                    }
                    else
                    {
                        <h5 class="text-secondary">&#9675; Not Clocked In</h5>
                        <p class="text-muted small mb-3">Start your shift</p>
                        <a asp-action="ClockIn" class="btn btn-success w-100">Clock In</a>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card text-center border-primary shadow-sm">
                        <div class="card-body">
                            <h3 class="text-primary">@todayHours h</h3>
                            <p class="text-muted mb-0">Today</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-info shadow-sm">
                        <div class="card-body">
                            <h3 class="text-info">@weekHours h</h3>
                            <p class="text-muted mb-0">This Week</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-success shadow-sm">
                        <div class="card-body">
                            <h3 class="text-success">@totalHours h</h3>
                            <p class="text-muted mb-0">All Time</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header"><strong>Session History</strong></div>
        <div class="card-body p-0">
            @if (!mySessions.Any())
            {
                <div class="p-3 text-muted">No sessions recorded yet.</div>
            }
            else
            {
                <table class="table table-striped table-sm mb-0">
                    <thead class="table-dark">
                    <tr>
                        <th>Clock In</th>
                        <th>Clock Out</th>
                        <th>Duration</th>
                        <th>Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var s in mySessions)
                    {
                        double hrs = s.ClockOutTime.HasValue
                            ? Math.Round((s.ClockOutTime.Value - s.ClockInTime).TotalHours, 2)
                            : 0;
                        <tr>
                            <td>@s.ClockInTime.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                            <td>
                                @if (s.ClockOutTime.HasValue)
                                {
                                    @s.ClockOutTime.Value.ToLocalTime().ToString("MMM d, h:mm tt")
                                }
                                else
                                {
                                    <span class="text-success small">Active</span>
                                }
                            </td>
                            <td>
                                @if (s.ClockOutTime.HasValue)
                                {
                                    <span>@hrs h</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (s.ClockOutTime.HasValue)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">In Progress</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
else
{
    <p class="text-muted">Overview of all staff clock-in/out activity</p>

    <!-- Manager Clock In/Out Card -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm @(openSession != null ? "border-success" : "border-secondary")">
                <div class="card-body text-center">
                    @if (openSession != null)
                    {
                        <h5 class="text-success">&#9679; You are Clocked In</h5>
                        <p class="text-muted small mb-3">
                            Since @openSession.ClockInTime.ToLocalTime().ToString("MMM d, h:mm tt")
                        </p>
                        <a asp-action="ClockOut" class="btn btn-danger w-100">Clock Out</a>
                    }
                    else
                    {
                        <h5 class="text-secondary">&#9675; Not Clocked In</h5>
                        <p class="text-muted small mb-3">Start your shift</p>
                        <a asp-action="ClockIn" class="btn btn-success w-100">Clock In</a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        @foreach (var s in allSessions.GroupBy(s => s.User != null ? s.User.Name : "Unknown"))
        {
            string workerName   = s.Key;
            bool   clocedIn     = s.Any(x => x.ClockOutTime == null);
            int    sessionCount = s.Count();
            double workerTotal  = Math.Round(
                s.Where(x => x.ClockOutTime.HasValue)
                 .Sum(x => (x.ClockOutTime!.Value - x.ClockInTime).TotalHours), 2);

            <div class="col-md-3">
                <div class="card shadow-sm @(clocedIn ? "border-success" : "border-secondary")">
                    <div class="card-body text-center">
                        <h6 class="fw-bold">@workerName</h6>
                        @if (clocedIn)
                        {
                            <span class="badge bg-success mb-2">&#9679; Clocked In</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary mb-2">&#9675; Off</span>
                        }
                        <p class="mb-0 text-muted small">@workerTotal h total &middot; @sessionCount sessions</p>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-header"><strong>All Sessions</strong></div>
        <div class="card-body p-0">
            @if (!allSessions.Any())
            {
                <div class="p-3 text-muted">No sessions recorded yet.</div>
            }
            else
            {
                <table class="table table-striped table-sm mb-0">
                    <thead class="table-dark">
                    <tr>
                        <th>Worker</th>
                        <th>Clock In</th>
                        <th>Clock Out</th>
                        <th>Duration</th>
                        <th>Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var s in allSessions)
                    {
                        double hrs = s.ClockOutTime.HasValue
                            ? Math.Round((s.ClockOutTime.Value - s.ClockInTime).TotalHours, 2)
                            : 0;
                        <tr>
                            <td><strong>@(s.User != null ? s.User.Name : "—")</strong></td>
                            <td>@s.ClockInTime.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                            <td>
                                @if (s.ClockOutTime.HasValue)
                                {
                                    @s.ClockOutTime.Value.ToLocalTime().ToString("MMM d, h:mm tt")
                                }
                                else
                                {
                                    <span class="text-success small">Active now</span>
                                }
                            </td>
                            <td>
                                @if (s.ClockOutTime.HasValue)
                                {
                                    <span>@hrs h</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (s.ClockOutTime.HasValue)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">In Progress</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
