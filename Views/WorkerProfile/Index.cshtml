@model IEnumerable<HotelHousekeepingSystem.Models.WorkerProfile>

@{
    ViewData["Title"] = "Worker Profiles";
}

<h2 class="mt-3">Worker Profiles</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">
        No worker profiles found. Workers will be prompted to fill in their details on registration.
    </div>
}
else
{
    <table class="table table-striped table-bordered mt-3">
        <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Role</th>
            <th>Nationality</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td><strong>@p.User.Name</strong></td>
                <td><span class="badge bg-secondary">@p.User.Role</span></td>
                <td>@p.Nationality</td>
                <td>@p.PhoneNumber</td>
                <td>@p.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@p.Id"
                       class="btn btn-sm btn-warning">Edit</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}